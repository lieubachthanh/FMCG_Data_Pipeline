# Environment configuration for FMCG Data Platform
# Copy to .env and adjust paths as needed

# ── Paths ──────────────────────────────────────────────────────────────────
FMCG_PROJECT_DIR=/opt/fmcg_platform
RAW_BASE=${FMCG_PROJECT_DIR}/data_lake/raw
CLEAN_BASE=${FMCG_PROJECT_DIR}/data_lake/clean
DW_PATH=${FMCG_PROJECT_DIR}/data_lake/fmcg_warehouse.duckdb

# ── Airflow ────────────────────────────────────────────────────────────────
AIRFLOW_UID=50000
AIRFLOW__CORE__FERNET_KEY=your_fernet_key_here

# ── Metabase ───────────────────────────────────────────────────────────────
METABASE_URL=http://localhost:3000
METABASE_EMAIL=admin@fmcg.local
METABASE_PASSWORD=admin123

# ── Spark ──────────────────────────────────────────────────────────────────
SPARK_SUBMIT=spark-submit
JAVA_HOME=/usr/lib/jvm/java-11-openjdk
